# Environment variables for MarketMind

# Environment (development, production, test)
NODE_ENV=development

# LLM Provider API Key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info

# Optional: Enable file logging (true/false)
LOG_TO_FILE=false

# Optional: Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Server port (default: 4000)
PORT=4000

# Optional: Frontend origin for CORS (default: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Optional: Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
