{
  "name": "marketmind",
  "version": "1.0.0",
  "description": "AI-assisted decision-support system for investors and traders",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build && npm run build:client",
    "start": "ts-node src/cli/analyze.ts",
    "dev": "ts-node-dev src/cli/analyze.ts",
    "dev:server": "ts-node-dev --respawn src/server.ts",
    "start:server": "ts-node src/server.ts",
    "prod:server": "NODE_ENV=production node dist/server.js",
    "dev:all": "concurrently \"npm run dev:server\" \"cd client && npm run dev\"",
    "docker:build": "docker build -t marketmind .",
    "docker:run": "docker run -p 4000:4000 --env-file .env marketmind",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:client": "cd client && npm run test:run",
    "lint": "eslint src/**/*.ts",
    "lint:client": "cd client && npm run lint",
    "format:client": "cd client && npm run format",
    "typecheck": "tsc --noEmit && cd client && npm run typecheck"
  },
  "keywords": [
    "market-analysis",
    "ai",
    "reasoning",
    "investment"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  }
}
